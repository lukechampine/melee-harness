{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/luke/melee/tools/check_inline_vars.py",
            "timeout": 10,
            "statusMessage": "Checking for inlined functions..."
          },
          {
            "type": "command",
            "command": "python3 /Users/luke/melee/tools/check_type_erasing_casts.py",
            "timeout": 10,
            "statusMessage": "Checking for type-erasing casts..."
          }
        ]
      }
    ]
  }
}
